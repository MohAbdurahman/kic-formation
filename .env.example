# ===========================================
# CONFIGURATION ENVIRONNEMENT - KIC-FORMATIONS
# ===========================================
# Copier ce fichier en .env.local et remplir les valeurs

# ===========================================
# DATABASE
# ===========================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/kic_formations"

# ===========================================
# STRIPE (Paiements)
# ===========================================
# Clé publique (visible côté client)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxx"

# Clé secrète (serveur uniquement - NE JAMAIS exposer)
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxx"

# Secret webhook pour vérifier les événements Stripe
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxx"

# ===========================================
# EMAIL (Resend ou SendGrid)
# ===========================================
# API Key du service d'email
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"
# Ou si SendGrid :
# SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxx"

# Email expéditeur
EMAIL_FROM="info@kic-formations.ch"

# Email destinataire pour les contacts
EMAIL_TO="info@kic-formations.ch"

# ===========================================
# GOOGLE SERVICES
# ===========================================
# Google Maps API Key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="AIzaSyxxxxxxxxxxxxxxxxx"

# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Google Site Verification (pour Search Console)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION="xxxxxxxxxxxxxxxxx"

# ===========================================
# SOCIAL MEDIA & MARKETING
# ===========================================
# Facebook Pixel ID
NEXT_PUBLIC_FB_PIXEL_ID="xxxxxxxxxxxxxxxxx"

# Instagram Access Token (si besoin API)
INSTAGRAM_ACCESS_TOKEN="xxxxxxxxxxxxxxxxx"

# ===========================================
# SITE CONFIGURATION
# ===========================================
# URL du site en production
NEXT_PUBLIC_SITE_URL="https://kic-formations.ch"

# Mode de l'application
NODE_ENV="development"

# ===========================================
# SÉCURITÉ
# ===========================================
# Secret pour JWT (si authentification custom)
JWT_SECRET="votre-secret-tres-securise-changez-moi"

# Secret pour les sessions
SESSION_SECRET="votre-secret-de-session-tres-securise"

# ===========================================
# OPTIONAL SERVICES
# ===========================================
# Sentry (monitoring d'erreurs)
# NEXT_PUBLIC_SENTRY_DSN="https://xxxxxxxxx@sentry.io/xxxxxxx"

# Cloudinary (si hébergement d'images)
# CLOUDINARY_CLOUD_NAME="xxxxxxxxx"
# CLOUDINARY_API_KEY="xxxxxxxxx"
# CLOUDINARY_API_SECRET="xxxxxxxxx"

# ===========================================
# DEVELOPMENT ONLY
# ===========================================
# Afficher les logs détaillés en dev
# DEBUG="true"

# Désactiver la télémétrie Next.js (optionnel)
# NEXT_TELEMETRY_DISABLED=1
